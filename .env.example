# Server
NODE_ENV=development
PORT=8080
PUBLIC_BASE_URL=http://localhost:8080
PRODUCT_CONFIG_PATH=./config/products.json

# State tokens protect returnUrl/product data during the Microsoft redirect.
# Use at least 32 random bytes in production.
STATE_SECRET=replace-with-at-least-32-random-characters

# Development signing. Use RS256 in production.
SESSION_SIGNING_ALG=HS256
SESSION_SECRET=replace-with-at-least-32-random-characters

# Production signing.
# SESSION_SIGNING_ALG=RS256
# SESSION_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# SESSION_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

SESSION_ISSUER=https://auth.helixrs.com
SESSION_TTL_SECONDS=28800
HANDOFF_CODE_TTL_SECONDS=120

# Product-specific Entra app registrations.
FILEGUARD_ENTRA_CLIENT_ID=
FILEGUARD_ENTRA_CLIENT_SECRET=
NEXTAPP_ENTRA_CLIENT_ID=
NEXTAPP_ENTRA_CLIENT_SECRET=
